# Exemplo para uso com st.secrets.
# Nao coloque senhas reais neste arquivo.

[usuarios]
"DMLIMA" = "troque_esta_senha"
"VICTOR" = "troque_esta_senha"

[google_sheets]
spreadsheet_id = "cole_o_id_da_planilha_aqui"
sheet_prefix = ""

[google_service_account]
type = "service_account"
project_id = "troque_isto"
private_key_id = "troque_isto"
private_key = "-----BEGIN PRIVATE KEY-----\ntroque_isto\n-----END PRIVATE KEY-----\n"
client_email = "troque_isto@troque_isto.iam.gserviceaccount.com"
client_id = "troque_isto"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "troque_isto"
universe_domain = "googleapis.com"
